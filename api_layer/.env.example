# CyberSense API — Environment Variables
# Copy to .env and fill in all values before starting the server

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_URL=https://cybersense.solutions
ALLOWED_ORIGINS=https://cybersense.solutions,https://admin.cybersense.solutions

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/cybersense

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_64_BYTE_HEX
JWT_REFRESH_SECRET=CHANGE_ME_64_BYTE_HEX_DIFFERENT

# ── Agent Tokens ──────────────────────────────────────────────────────────────
# Separate secret for agent service tokens — never share with users
AGENT_JWT_SECRET=CHANGE_ME_64_BYTE_HEX_AGENT
# Internal service-to-service shared secret (for agent webhook calls)
INTERNAL_SECRET=CHANGE_ME_32_BYTE_HEX

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_XXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXX
STRIPE_PRICE_MONTHLY=price_XXXXX
STRIPE_PRICE_ENTERPRISE=price_XXXXX

# ── SendGrid ──────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.XXXXX
FROM_EMAIL=noreply@cybersense.solutions
SG_TEMPLATE_VERIFY=d-XXXXX
SG_TEMPLATE_RESET=d-XXXXX
SG_TEMPLATE_WELCOME=d-XXXXX
SG_TEMPLATE_BRIEFING=d-XXXXX

# ── Agent Webhook Base URL ────────────────────────────────────────────────────
# Base URL for internal agent notification webhooks
# Each agent listens at AGENT_WEBHOOK_BASE/{agent_name_lowercase}/notify
AGENT_WEBHOOK_BASE=http://localhost:4000/agents

# ── AWS S3 (Training Content) ─────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=XXXXX
AWS_SECRET_ACCESS_KEY=XXXXX
AWS_REGION=us-east-1
S3_BUCKET_TRAINING=cybersense-training-content
