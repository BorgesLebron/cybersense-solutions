# CyberSense — Manual Pipeline Trigger Config
# Copy to .tools/.env and fill in values
# This file is NEVER committed — it stays local only

# Production API
CS_API_URL=https://api.cybersense.solutions

# Admin email (must have gm role in admin_roles table)
# Password is NEVER stored — always prompted at runtime
CS_ADMIN_EMAIL=your-admin@cybersense.solutions
